# sync/.env.example — copy to sync/.env and fill in. NEVER commit sync/.env.
# The real sync/.env is gitignored. Values below are placeholders only.

# --- Procore (production data connection app — DMSA / client credentials) ---
# Reuse the existing app registration; do NOT create a new one.
PROCORE_CLIENT_ID=your-production-client-id
PROCORE_CLIENT_SECRET=your-production-client-secret
PROCORE_COMPANY_ID=8906

# Allowlist of project ids the deep loop may fetch (comma-separated). Defense-in-depth
# on top of the DMSA's permitted-projects list. Starts as Orchard Path III ONLY;
# add McKenna here (and in Procore App Management) once it is permitted on the app.
# Tip: run the pipeline once with this blank — it logs every discovered project id,
# then aborts before any deep fetch so you can paste the id in.
ACTIVE_PROJECT_IDS=

# --- Supabase (the FRESH project — filled in after provisioning) ---
# Use the SESSION pooler connection (port 5432). Find these under
# Project Settings → Database → Connection string / Connection pooling.
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_HOST=aws-1-REGION.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres

# --- Procore Sandbox (only for the two sandbox smoke-test scripts) ---
PROCORE_SANDBOX_CLIENT_ID=your-sandbox-client-id
PROCORE_SANDBOX_CLIENT_SECRET=your-sandbox-client-secret
PROCORE_SANDBOX_COMPANY_ID=your-sandbox-company-id
PROCORE_SANDBOX_PROJECT_ID=your-sandbox-project-id
