{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sitelines-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "sitelines-seed",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-Command", "$env:VITE_DATA_SOURCE='seed'; npx vite --port 5174 --strictPort"],
      "port": 5174
    },
    {
      "name": "sitelines-live",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-Command", "$env:VITE_DATA_SOURCE='live'; npx vite --port 5175 --strictPort"],
      "port": 5175
    }
  ]
}
