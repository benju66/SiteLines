# Frontend env (Vite). Copy to .env.local and fill in. .env.local is gitignored.
# Leave VITE_DATA_SOURCE unset (or =seed) to run on in-file seed data.
# Set =live to read the Supabase normalization views (requires the RLS read policy).

VITE_DATA_SOURCE=seed
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (public by design; what it can read is governed by RLS).
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
